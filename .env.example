# MongoDB Connection URI (Atlas recommended)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/helpnet

# NextAuth Configuration
# Run `openssl rand -base64 32` or similar to generate a random secret key
NEXTAUTH_SECRET=your_32_character_nextauth_secret_key
NEXTAUTH_URL=http://localhost:3000

# Supabase Configurations (for Real-time WebSockets)
# Get these from project settings in the Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Cloudinary Configuration for Image Uploads
# Create a free account at Cloudinary and set up an unsigned preset called 'helpnet_avatars'
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=helpnet_avatars

# Cron endpoint protection secret
CRON_SECRET=your_cron_endpoint_secret
